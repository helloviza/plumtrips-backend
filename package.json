{
  "name": "@plumtrips/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "tsx --env-file=./.env --watch src/server.ts",
    "clean": "rimraf dist || rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/server.js",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1042.0",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-validator": "^7.3.2",
    "google-auth-library": "^10.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.17.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "pdfkit": "^0.19.1",
    "puppeteer": "^25.3.0",
    "razorpay": "^2.9.6",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.4",
    "typescript": "^5.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.43",
    "@types/pdfkit": "^0.17.6"
  }
}
